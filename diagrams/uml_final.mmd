classDiagram
    %% Keep this file updated so it matches your final implementation.

    class Frequency {
        <<enumeration>>
        DAILY
        WEEKLY
        ONCE
    }

    class Priority {
        <<enumeration>>
        HIGH
        MEDIUM
        LOW
    }

    class Task {
        +str description
        +int duration_minutes
        +Frequency frequency
        +Priority priority
        +str time
        +bool completed
        +Optional~date~ due_date
        +mark_completed() Optional~Task~
    }

    class Pet {
        +str name
        +str breed
        +int age
        +list tasks
        +add_task(task) None
        +remove_task(task) None
        +get_tasks() list
    }

    class Owner {
        +str name
        +list pets
        +add_pet(pet) None
        +remove_pet(pet) None
    }

    class Scheduler {
        +Owner owner
        +int max_daily_minutes
        +generate_plan(pet, today) list
        +sort_by_time(tasks) list
        +filter_tasks(tasks, completed, pet_name, today) list
        +complete_task(pet, task) Optional~Task~
        +detect_conflicts(scheduled) list
        +detect_time_conflicts(today) list
    }

    Owner "1" --> "0..*" Pet : owns
    Pet "1" --> "0..*" Task : has
    Scheduler "1" --> "1" Owner : schedules for
    Scheduler ..> Task : filters, sorts, completes
    Task --> Frequency : uses
    Task --> Priority : uses
